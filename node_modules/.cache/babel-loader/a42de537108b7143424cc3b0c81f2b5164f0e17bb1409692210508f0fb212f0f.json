form: rotate(0deg); }\r\r\n  100% { transform: rotate(360deg); }\r\r\n}\r\r\n</style> \r\n"],"mappings":"eAWe;MAET,EAAE,gBAAE;OAEH,EAAE;IAELA,IAAI,EAAE;MAEJC,IAAI,EAAEC,MAAM;MAEhB","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}