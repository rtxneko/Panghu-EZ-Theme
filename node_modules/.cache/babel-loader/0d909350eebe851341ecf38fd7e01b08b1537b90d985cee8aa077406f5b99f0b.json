{"ast":null,"code":"import \"core-js/modules/web.timers.js\";\nimport { ref, onMounted, onUnmounted, computed } from 'vue';\nimport { useStore } from 'vuex';\nimport { IconChevronsUp } from '@tabler/icons-vue';\nexport default {\n  name: 'BackToTop',\n  components: {\n    IconChevronsUp: IconChevronsUp\n  },\n  setup: function setup() {\n    var visible = ref(false);\n    var store = useStore();\n    var isDarkTheme = computed(function () {\n      return store.getters.currentTheme === 'dark';\n    });\n    var isMobileDevice = ref(false);\n    var checkDeviceType = function checkDeviceType() {\n      isMobileDevice.value = window.innerWidth < 770;\n    };\n    var checkScroll = function checkScroll() {\n      visible.value = window.scrollY > 100;\n    };\n    var scrollToTop = function scrollToTop() {\n      var currentPosition = window.pageYOffset;\n      window.scrollTo(0, currentPosition * 0.8);\n      var currentPos = window.pageYOffset;\n      var scrollInterval = setInterval(function () {\n        if (currentPos <= 0) {\n          clearInterval(scrollInterval);\n          window.scrollTo(0, 0);\n          return;\n        }\n        var scrollStep = Math.max(currentPos * 0.3, 10);\n        currentPos = currentPos - scrollStep;\n        window.scrollTo(0, currentPos);\n      }, 15);\n    };\n    onMounted(function () {\n      window.addEventListener('scroll', checkScroll, {\n        passive: true\n      });\n      window.addEventListener('resize', checkDeviceType, {\n        passive: true\n      });\n      checkScroll();\n      checkDeviceType();\n    });\n    onUnmounted(function () {\n      window.removeEventListener('scroll', checkScroll);\n      window.removeEventListener('resize', checkDeviceType);\n    });\n    return {\n      visible: visible,\n      isMobileDevice: isMobileDevice,\n      scrollToTop: scrollToTop,\n      isDarkTheme: isDarkTheme\n    };\n  }\n};","map":{"version":3,"names":["ref","onMounted","onUnmounted","computed","IconChevronsUp","set