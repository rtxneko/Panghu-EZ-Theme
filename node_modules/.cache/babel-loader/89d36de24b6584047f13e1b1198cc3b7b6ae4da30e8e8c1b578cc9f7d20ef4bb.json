opacity: 0;\r\r\n    transform: translateY(10px) scale(0.98);\r\r\n  }\r\r\n  to {\r\r\n    opacity: 1;\r\r\n    transform: translateY(0) scale(1);\r\r\n  }\r\r\n}\r\r\n\r\r\n@keyframes modal-out {\r\r\n  from {\r\r\n    opacity: 1;\r\r\n    transform: scale(1);\r\r\n  }\r\r\n  to {\r\r\n    opacity: 0;\r\r\n    transform: scale(0.95);\r\r\n  }\r\r\n}\r\r\n\r\r\n.fade-enter-active {\r\r\n  transition: opacity 0.3s ease;\r\r\n}\r\r\n\r\r\n.fade-leave-active {\r\r\n  transition: opacity 0.5s ease;\r\r\n}\r\r\n\r\r\n.fade-enter-from,\r\r\n.fade-leave-to {\r\r\n  opacity: 0;\r\r\n}\r\r\n\r\r\n\r\r\n@media (max-width: 768px) {\r\r\n  .shop-popup-overlay {\r\r\n    padding: 15px;\r\r\n    \r\r\n    .shop-popup-container {\r\r\n      max-width: 100%;\r\r\n      max-height: 85vh;\r\r\n      \r\r\n      .shop-popup-header {\r\r\n        padding: 15px;\r\r\n        \r\r\n        .popup-title {\r\r\n          font-size: 16px;\r\r\n        }\r\r\n      }\r\r\n      \r\r\n      .shop-popup-content {\r\r\n        padding: 15px;\r\r\n      }\r\r\n      \r\r\n      .shop-popup-footer {\r\r\n        padding: 12px 15px;\r\r\n      }\r\r\n    }\r\r\n  }\r\r\n}\r\r\n</style> \r\n"],"mappings":";;EAGW,SAAM;AAAsB;;EAC1B,SAAM;AAAmB;;;EAMzB,SAAM;AAAoB;;;EAG1B,SAAM;AAAmB;;;;uBAZpCA,YAAA,CA4BaC,WAAA;IA5BDC,IAAI,EAAC;EAAM;wBAAQ;MAAA,OA2B8d,CA1BhfC,MAAA,CAAAC,IAAI,I,cAAfC,mBAAA,CA0BM;;QA1BW,SAAM,oBAAoB;QAAEC,OAAK,EAAAC,MAAA,QAAAA,MAAA,MAAAC,cAAA;UAAA,OAAOL,MAAA,CAAAM,YAAA,IAAAN,MAAA,CAAAM,YAAA,CAAAC,KAAA,CAAAP,MAAA,EAAAQ,SAAA,CAAY;QAAA;UACnEC,mBAAA,CAwBM,OAxBNC,UAwBM,GAvBJD,mBAAA,CAKM,OALNE,UAKM,GAJJF,mBAAA,CAA4C;QAAxC,SAAM,aAAa;QAACG,SAAc,EAANC,MAAA,CAAAC;2CAChCL,mBAAA,CAES;QAFD,SAAM,iBAAiB;QAAEN,OAAK,EAAAC,MAAA,QAAAA,MAAA;UAAA,OAAEJ,MAAA,CAAAM,YAAA,IAAAN,MAAA,CAAAM,YAAA,CAAAC,KAAA,CAAAP,MAAA,EAAAQ,SAAA,CAAY;QAAA;UAClDO,YAAA,CAAoBC,gBAAA;QAAZC,IAAI,EAAE;MAAE,G,KAGpBR,mBAAA,CAEM,OAFNS,UAEM,GADJT,mBAAA,CAA4B;QAAvBG,SAAgB,EAARC,MAAA,CAAAM;MAAO,wBAAAC,UAAA,E,GAEtBX,mBAAA,CAaM,OAbNY,UAaM,GAZJZ,mBA