p-popup-content\">\r\r\n          <div v-html=\"content\"></div>\r\r\n        </div>\r\r\n        <div class=\"shop-popup-footer\">\r\r\n          <button \r\r\n            class=\"popup-action-btn\" \r\r\n            @click=\"attemptClose\"\r\r\n            :disabled=\"waitTimeRemaining > 0\"\r\r\n          >\r\r\n            <template v-if=\"waitTimeRemaining > 0\">\r\r\n              {{ $t('shop.popup.wait_close_btn', { seconds: waitTimeRemaining }) }}\r\r\n            </template>\r\r\n            <template v-else>\r\r\n              {{ $t('shop.popup.close_btn') }}\r\r\n            </template>\r\r\n          </button>\r\r\n        </div>\r\r\n      </div>\r\r\n    </div>\r\r\n  </transition>\r\r\n</template>\r\r\n\r\r\n<script>\r\r\nimport { ref, watch, onUnmounted } from 'vue';\r\r\nimport { IconX } from '@tabler/icons-vue';\r\r\n\r\r\nexport default {\r\r\n  name: 'ShopPopup',\r\r\n  components: {\r\r\n    IconX\r\r\n  },\r\r\n  props: {\r\r\n    showPopup: {\r\r\n      type: Boolean,\r\r\n      default: false\r\r\n    },\r\r\n    title: {\r\r\n      type: String,\r\r\n      default: ''\r\r\n    },\r\r\n    content: {\r\r\n      type: String,\r\r\n      default: ''\r\r\n    },\r\r\n    cooldownHours: {\r\r\n      type: Number,\r\r\n      default: 24\r\r\n    },\r\r\n    closeWaitSeconds: {\r\r\n      type: Number,\r\r\n      default: 0\r\r\n    }\r\r\n  },\r\r\n  emits: ['close'],\r\r\n  setup(props, { emit }) {\r\r\n    const show = ref(false);\r\r\n    const waitTimeRemaining = ref(0);\r\r\n    let countdownTimer = null;\r\r\n    \r\r\n    const startCountdown = () => {\r\r\n      if (countdownTimer) {\r\r\n        clearInterval(countdownTimer);\r\r\n      }\r\r\n      \r\r\n      if (props.closeWaitSeconds > 0) {\r\r\n        waitTimeRemaining.value = props.closeWaitSeconds;\r\r\n        \r\r\n        countdownTimer = setInterval(() => {\r\r\n          if (waitTimeRemaining.value > 0) {\r\r\n            waitTimeRemaining.value -= 1;\r\r\n          } else {\r\r\n            clearInterval(countdownTimer);\r\r\n          }\r\r\n        }, 1000);\r\r\n      } else {\r\r\n        waitTimeRemaining.value = 0;\r\r\n      }\r\r\n    };\r\r\n    \r\r\n    const attemptClose = () => {\r\r\n      if (waitTimeRemaining.value > 0) {\r\r\n        return;\r\r\n      }\r\r\n      \r\r\n      show.value = false;\r\r\n      \r\r\n      if (props.cooldownHours > 0) {\r\r\n        const closeTime = new Date().getTime();\r\r\n        localStorage.setItem('shop_popup_close_time', closeTime.toString());\r\r\n      }\r\r\n      \r\r\n      emit('close');\r\r\n    };\r\r\n    \r\r\n    watch(() => props.showPopup, (newVal) => {\r\r\n      if (newVal) {\r\r\n        setTimeout(() => {\r\r\n          if (props.cooldownHours === 0) {\r\r\n            show.value = true;\r\r\n            startCountdown();\r\r\n            return;\r\r\n          }\r\r\n          \r\r\n          const closeTime = localStorage.getItem('shop_popup_close_time');\r\r\n          if (closeTime) {\r\r\n            const now = new Date().getTime();\r\r\n            const elapsed = now - parseInt(closeTime);\r\r\n            const cooldownMs = props.cooldownHours * 60 * 60 * 1000;\r\r\n            \r\r\n            if (elapsed >= cooldownMs) {\r\r\n              show.value = true;\r\r\n              startCountdown();\r\r\n            } else {\r\r\n              emit('close');\r\r\n            }\r\r\n          } else {\r\r\n            show.value = true;\r\r\n            startCountdown();\r\r\n          }\r\r\n        }, 500); \r\n      } else {\r\r\n        show.value = false;\r\r\n        if (countdownTimer) {\r\r\n          clearInterval(countdownTimer);\r\r\n        }\r\r\n      }\r\r\n    }, { immediate: true });\r\r\n    \r\r\n    onUnmounted(() => {\r\r\n      if (countdownTimer) {\r\r\n        clearInterval(countdownTimer);\r\r\n      }\r\r\n    });\r\r\n    \r\r\n    return {\r\r\n      show,\r\r\n      attemptClose,\r\r\n      waitTimeRemaining\r\r\n    };\r\r\n  }\