.tls_settings.server_port !== props.node.port.toString()) {\n                  vlessUrl += \"&port=\".concat(encodeURIComponent(props.node.tls_settings.server_port));\n                }\n                if (props.node.tls_settings.allow_insecure === '1') {\n                  vlessUrl += \"&allowInsecure=1\";\n                }\n              }\n            }\n            if (props.node.path) {\n              vlessUrl += \"&path=\".concat(encodeURIComponent(props.node.path));\n            }\n            vlessUrl += \"#\".concat(encodeURIComponent(props.node.name));\n            return vlessUrl;\n          }\n        case 'trojan':\n          {\n            var trojanUrl = \"trojan://\".concat(userUuid, \"@\").concat(props.node.host, \":\").concat(props.node.port);\n            if (props.node.allow_insecure) {\n              trojanUrl += '?allowInsecure=1';\n            }\n            trojanUrl += \"#\".concat(encodeURIComponent(props.node.name));\n            return trojanUrl;\n          }\n        case 'hysteria':\n          {\n            var hysteria2Url = \"hysteria2://\".concat(userUuid, \"@\").concat(props.node.host, \":\").concat(props.node.port);\n            var queryParams = [];\n            if (props.node.sni) {\n              queryParams.push(\"sni=\".concat(encodeURIComponent(props.node.sni)));\n            }\n            queryParams.push(\"insecure=\".concat(props.node.allow_insecure ? '1' : '0'));\n            if (queryParams.length > 0) {\n              hysteria2Url += \"?\".concat(queryParams.join('&'));\n            }\n            hysteria2Url += \"#\".concat(encodeURIComponent(props.node.name));\n            return hysteria2Url;\n          }\n        default:\n          return t('nodes.unsupportedNodeType') || '不支持的类型';\n      }\n    });\n    var updateQrCode = function updateQrCode() {\n      if (subscribeLink.value) {\n        qrCodeLoading.value = true;\n        try {\n          QRCode.toDataURL(subscribeLink.value, {\n            width: 200,\n            margin: 2,\n            color: {\n              dark: '#000000',\n              light: '#ffffff'\n            }\n          }).then(function (url) {\n            qrCodeUrl.value = url;\n            qrCodeLoading.value = false;\n          })[\"catch\"](function (err) {\n            console.error('二维码生成失败:', err);\n            qrCodeLoading.value = false;\n            showToast(t('common.qrCodeGenerationFailed') || '二维码生成失败', 'error');\n          });\n        } catch (error) {\n          console.error('生成二维码失败:', error);\n          qrCodeLoading.value = false;\n          showToast(t('common.qrCodeGenerationFailed') || '二维码生成失败', 'error');\n        }\n      }\n    };\n    var qrCodeLoaded = function qrCodeLoaded() {\n      qrCodeLoading.value = false;\n    };\n    var copySubscribeLink = function copySubscribeLink() {\n      navigator.clipboard.writeText(subscribeLink.value).then(function () {\n        showToast(t('common.copied') || '已复制到剪贴板', 'success');\n      })[\"catch\"](function (err) {\n        console.error('无法复制链接: ', err);\n        try {\n          var textarea = document.createElement('textarea');\n          textarea.value = subscribeLink.value;\n          textarea.style.position = 'fixed';\n          document.body.appendChild(textarea);\n          textarea.focus();\n          textarea.select();\n          var successful = document.execCommand('copy');\n          document.body.removeChild(textarea);\n          if (successful) {\n            showToast(t('common.copied') || '已复制到剪贴板', 'success');\n          } else {\n            showToast(t('common.copyFailed') || '复制失败', 'error');\n          }\n        } catch (fallbackErr) {\n          console.error('后备复制方法也失败:', fallbackErr);\n          showToast(t('common.copyFailed') || '复制失败', 'error');\n        }\n      });\n    };\n    watchEffect(function () {\n      if (viewMode.value === 'qrcode' && props.show && currentPage.value === 'subscribe') {\n        updateQrCode();\n      }\n    });\n    watchEff