:\", 1 /* TEXT */), _createElementVNode(\"span\", _hoisted_8, _toDisplayString($props.node.type), 1 /* TEXT */)]), _createElementVNode(\"div\", _hoisted_9, [_createElementVNode(\"span\", _hoisted_10, _toDisplayString(_ctx.$t('nodes.rate')) + \":\", 1 /* TEXT */), _createElementVNode(\"span\", {\n            \"class\": _normalizeClass([\"info-value\", {\n              'high-rate': parseFloat($props.node.rate) != 1\n            }])\n          }, \"x\" + _toDisplayString($props.node.rate), 3 /* TEXT, CLASS */)]), _createElementVNode(\"div\", _hoisted_11, [_createElementVNode(\"span\", _hoisted_12, _toDisplayString(_ctx.$t('nodes.host')) + \":\", 1 /* TEXT */), _createElementVNode(\"span\", _hoisted_13, _toDisplayString($props.node.host), 1 /* TEXT */)]), _createElementVNode(\"div\", _hoisted_14, [_createElementVNode(\"span\", _hoisted_15, _toDisplayString(_ctx.$t('nodes.port')) + \":\", 1 /* TEXT */), _createElementVNode(\"span\", _hoisted_16, _toDisplayString($props.node.port), 1 /* TEXT */)]), _createCommentVNode(\" 根据节点类型显示不同的信息 \"), $props.node.type === 'ss' || $props.node.type === 'shadowsocks' ? (_openBlock(), _createElementBlock(\"div\", _hoisted_17, [_createElementVNode(\"span\", _hoisted_18, _toDisplayString(_ctx.$t('nodes.cipher')) + \":\", 1 /* TEXT */), _createElementVNode(\"span\", _hoisted_19, _toDisplayString($props.node.cipher), 1 /* TEXT */)])) : _createCommentVNode(\"v-if\", true), $props.node.type === 'trojan' ? (_openBlock(), _createElementBlock(\"div\", _hoisted_20, [_createElementVNode(\"span\", _hoisted_21, _toDisplayString(_ctx.$t('nodes.security')) + \":\", 1 /* TEXT */), _createElementVNode(\"span\", _hoisted_22, _toDisplayString($props.node.allow_insecure ? _ctx.$t('nodes.allowInsecure') : _ctx.$t('nodes.secure')), 1 /* TEXT */)])) : _createCommentVNode(\"v-if\", true), $props.node.type === 'vmess' ? (_openBlock(), _createElementBlock(\"div\", _hoisted_23, [_createElementVNode(\"span\", _hoisted_24, _toDisplayString(_ctx.$t('nodes.tls') || 'T