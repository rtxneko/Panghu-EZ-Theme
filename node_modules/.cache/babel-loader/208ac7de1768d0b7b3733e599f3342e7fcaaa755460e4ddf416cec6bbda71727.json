left: 0;\r\r\n  height: 3px;\r\r\n  width: 100%;\r\r\n  transform-origin: left;\r\r\n  animation: progress-bar-shrink 3000ms linear forwards;\r\r\n  animation-play-state: running;\r\r\n  opacity: 0.8;\r\r\n  will-change: transform;\r\r\n}\r\r\n\r\r\n@keyframes progress-bar-shrink {\r\r\n  0% {\r\r\n    transform: scaleX(1);\r\r\n  }\r\r\n  100% {\r\r\n    transform: scaleX(0);\r\r\n  }\r\r\n}\r\r\n\r\r\n.toast-list-enter-active {\r\r\n  transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);\r\r\n  transition-delay: 0.1s;\r\r\n}\r\r\n\r\r\n.toast-list-leave-active {\r\r\n  transition: all 0.4s cubic-bezier(0.6, 0.04, 0.98, 0.335);\r\r\n  position: absolute;\r\r\n  \r\r\n  @media (max-width: 576px) {\r\r\n    width: calc(100% - 32px);\r\r\n    left: 16px;\r\r\n    right: 16px;\r\r\n  }\r\r\n}\r\r\n\r\r\n.toast-list-enter-from {\r\r\n  opacity: 0;\r\r\n  transform: translateX(100%);\r\r\n  \r\r\n  @media (max-width: 576px) {\r\r\n    transform: translateY(-100%);\r\r\n  }\r\r\n}\r\r\n\r\r\n.toast-list-leave-to {\r\r\n  opacity: 0;\r\r\n  transform: translateX(100%);\r\r\n  \r\r\n  @media (max-width: 576px) {\r\r\n    transform: translateY(-100%);\r\r\n  }\r\r\n}\r\r\n</style> \r\n"],"mappings":";;;EAYW,SAAM;AAAY;;;EAKlB,SAAM;AAAe;;EAGrB,SAAM;AAAa;;;;uBAnB5BA,YAAA,CA0BmBC,gBAAA;IA1BDC,GAAG,EAAC,KAAK;IAACC,IAAI,EAAC,YAAY;IAAC,SAAM;;wBAEhD;MAAA,OAAuB,E,kBADzBC,mBAAA,CAwBMC,SAAA,QAAAC,WAAA,CAvBYC,MAAA,CAAAC,MAAM,YAAfC,KAAK;6BADdL,mBAAA,CAwBM;UAtBHM,GAAG,EAAED,KAAK,CAACE,EAAE;UACd,SAAKC,eAAA,EAAC,OAAO,YAAAC,MAAA,CACKJ,KAAK,CAACK,IAAI;YAAA,cAAoBL,KAAK,CAACM;UAAI;UACzD,SAAO,EAAEN,KAAK,CAACE,EAAE;UACjBK,OAAK,WAALA,OAAKA,CAAAC,MAAA;YAAA,OAAEV,MAAA,CAAAW,WAAW,CAACT,KAAK,CAACE,EAAE;UAAA;UAC3BQ,YAAU,WAAVA,YAAUA,CAAAF,MAAA;YAAA,OAAEV,MAAA,CAAAa,eAAe,CAACX,KAAK,CAACE,EAAE;UAAA;UACpCU,YAAU,WAAVA,YAAUA,CAAAJ,MAAA;YAAA,OAAEV,MAAA,CAAAe,gBAAgB,CAACb,KAAK,CAACE,EAAE;UAAA;YAEtCY,mBAAA,CAIM,OAJNC,UAIM,I,cAHJpB,mBAAA,CAEM;UAFD,SAAKQ,eAAA,EAAC,MAAM,EAASL,MAAA,CAAAkB,YAAY,CAAChB,KAAK,CAACK,IAAI;